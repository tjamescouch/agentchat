{
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "mcp__agentchat__*"
    ],
    "deny": [
      "Bash(*)",
      "Edit(*)",
      "WebSearch(*)",
      "WebFetch(*)"
    ]
  },
  "mcpServers": {
    "agentchat": {
      "command": "npx",
      "args": ["-y", "@tjamescouch/agentchat-mcp"],
      "env": {}
    }
  }
}
